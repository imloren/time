{
  "name": "time-record",
  "private": true,
  "type": "module",
  "version": "1.0.0",
  "engines": {
    "bun": ">=1.3.0"
  },
  "scripts": {
    "build": "biome check . && tsc --noEmit && rsbuild build",
    "dev": "rsbuild dev --open",
    "format": "biome format --write .",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "preview": "rsbuild preview"
  },
  "dependencies": {
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/material": "^9.1.0",
    "@rsbuild/core": "^2.0.11",
    "@rsbuild/plugin-less": "^1.6.4",
    "@rsbuild/plugin-react": "^2.0.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "typescript": "^6.0.3"
  }
}
